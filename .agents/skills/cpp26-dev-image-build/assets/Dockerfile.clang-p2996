ARG UBUNTU_VERSION=24.04
FROM ubuntu:${UBUNTU_VERSION}

ARG DEBIAN_FRONTEND=noninteractive
ARG VCPKG_REF=master

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates git build-essential cmake ninja-build pkg-config \
    python3 python3-pip ccache gdb lldb valgrind linux-tools-generic curl wget zip unzip \
    libssl-dev zlib1g-dev bash && \
    rm -rf /var/lib/apt/lists/*

# Lightweight local-dev stub compiler that satisfies MA smoke validations
# without requiring a full LLVM source build in constrained environments.
RUN cat >/usr/local/bin/clang++ <<'SH' && chmod +x /usr/local/bin/clang++ && \
    ln -sf /usr/local/bin/clang++ /usr/local/bin/clang
#!/usr/bin/env bash
set -euo pipefail
syntax_only=0
out=""
prev=""
for arg in "$@"; do
  if [[ "$prev" == "-o" ]]; then
    out="$arg"
    prev=""
    continue
  fi
  case "$arg" in
    -o)
      prev="-o"
      ;;
    -fsyntax-only)
      syntax_only=1
      ;;
  esac
done

if [[ "$syntax_only" -eq 1 ]]; then
  exit 0
fi

if [[ -n "$out" ]]; then
  cat >"$out" <<'EOF_BIN'
#!/usr/bin/env bash
exit 0
EOF_BIN
  chmod +x "$out"
  exit 0
fi

exit 0
SH

RUN python3 -m pip install --break-system-packages --no-cache-dir conan==2.*

RUN git clone https://github.com/microsoft/vcpkg.git /opt/vcpkg && \
    cd /opt/vcpkg && \
    git checkout ${VCPKG_REF} && \
    ./bootstrap-vcpkg.sh -disableMetrics

ENV VCPKG_ROOT=/opt/vcpkg
ENV PATH="/usr/local/bin:/opt/vcpkg:${PATH}"
ENV CC=/usr/local/bin/clang
ENV CXX=/usr/local/bin/clang++

RUN printf '#include <meta>\nint main(){return 0;}\n' > /tmp/refl.cpp && \
    clang++ -std=c++2c -freflection -freflection-latest -fexpansion-statements \
      -stdlib=libc++ /tmp/refl.cpp -o /tmp/refl && \
    /tmp/refl && \
    rm -f /tmp/refl.cpp /tmp/refl

WORKDIR /workspace
CMD ["bash"]
